<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <%- include('../partials/nav') %>

    <div class="bg-white shadow-sm px-8 py-8 text-center">
      <h2 class="text-5xl font-extrabold text-red-500 mb-2 tracking-wide">✨ Our Registered Events</h2>
      <p class="text-gray-500 text-lg mb-4">Explore the most beautiful decoration services near you</p>
      <div class="w-24 h-1 bg-red-400 mx-auto rounded-full"></div>
    </div>

    <main class="w-full px-8 py-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% registeredevents.forEach(event => { %>
          <div class="group bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-2xl hover:-translate-y-2 hover:scale-105 transition-all duration-300">

            <!-- Image -->
            <div class="relative overflow-hidden">
              <img src="<%= event.photo %>" alt="<%= event.EventName %>"
                class="w-full h-52 object-cover group-hover:scale-110 transition-transform duration-500">
              
              <!-- Rating Badge -->
              <div class="absolute top-2 right-2 bg-black bg-opacity-60 text-white text-xs font-bold px-2 py-1 rounded-full flex items-center gap-1">
                ⭐ <%= event.rating %>
              </div>

              <% if(event.video) { %>
                <a href="<%= event.video %>" target="_blank"
                  class="absolute bottom-2 right-2 bg-black bg-opacity-60 hover:bg-opacity-90 text-white text-xs font-semibold px-3 py-1 rounded-full flex items-center gap-1 transition duration-200">
                  🎥 Watch Video
                </a>
              <% } %>
            </div>

            <!-- Content -->
            <div class="p-4">

              <!-- Shop Name Badge -->
              <span class="inline-block bg-red-100 text-red-500 text-xs font-bold px-2 py-1 rounded-full mb-2 uppercase tracking-wide">
                🏪 <%= event.shopName %>
              </span>

              <h3 class="text-lg font-bold text-gray-800 mb-1 group-hover:text-red-500 transition duration-200">
                <%= event.EventName %>
              </h3>

              <p class="text-gray-400 text-sm mb-3">
                <i class="fas fa-map-marker-alt mr-1 text-red-400"></i><%= event.location %>
              </p>

              <div class="flex justify-between items-center mb-4">
                <span class="text-lg font-extrabold text-red-500">
                  Rs<%= event.price %>
                  <span class="text-xs font-normal text-gray-400">/ night</span>
                </span>
              </div>

              <div class="flex flex-col gap-2">
                <a href="/events/<%= event._id %>"
                  class="w-full bg-blue-400 hover:bg-blue-500 active:scale-95 text-white font-semibold py-2 px-4 rounded-xl transition-all duration-200 text-center block">
                  View Details
                </a>
                <%- include('../partials/favourite', {event: event}) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>

  </body>
</html>
