<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <%- include('../partials/nav') %>

    <div class="bg-white shadow-sm px-8 py-8 text-center">
      <h2 class="text-5xl font-extrabold text-red-500 mb-2 tracking-wide">🏠 Welcome to DecorBnB</h2>
      <p class="text-gray-500 text-lg mb-6">Find & book the most beautiful decorated spaces near you</p>
      <div class="w-24 h-1 bg-red-400 mx-auto mb-6 rounded-full"></div>
      <div class="flex items-center bg-gray-100 rounded-xl px-4 py-3 max-w-2xl mx-auto">
        <i class="fas fa-search text-gray-400 mr-3"></i>
        <input type="text" id="searchInput" placeholder="Search events, locations..."
          class="bg-transparent w-full outline-none text-gray-700 text-base" onkeyup="filterEvents()"/>
      </div>
    </div>

    <main class="w-full px-8 py-10">
      <div id="eventList" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% registeredevents.forEach(event => { %>
          <div class="event-card group bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300"
               data-name="<%= event.EventName %>"
               data-location="<%= event.location %>">

            <!-- Image -->
            <div class="relative overflow-hidden">
              <img src="<%= event.photo %>" alt="<%= event.EventName %>"
                class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-300">
              <% if(event.video) { %>
                <a href="<%= event.video %>" target="_blank"
                  class="absolute bottom-2 right-2 bg-black bg-opacity-60 hover:bg-opacity-90 text-white text-xs font-semibold px-3 py-1 rounded-full flex items-center gap-1 transition duration-200">
                  🎥 Watch Video
                </a>
              <% } %>
            </div>

            <!-- Content -->
            <div class="p-4">

              <!-- Shop Name Badge (Stylish & Big) -->
              <div class="mb-3">
                <span class="inline-flex items-center gap-2 bg-gradient-to-r from-red-500 to-pink-500 text-white text-sm font-extrabold px-4 py-2 rounded-full shadow-lg uppercase tracking-widest">
                  🏪 <%= event.shopName %>
                </span>
              </div>

              <h3 class="text-lg font-bold text-gray-800 mb-1 group-hover:text-red-500 transition duration-200">
                <%= event.EventName %>
              </h3>

              <p class="text-gray-400 text-sm mb-2">
                <i class="fas fa-map-marker-alt mr-1 text-red-400"></i><%= event.location %>
              </p>

              <div class="flex justify-between items-center mb-3">
                <span class="text-lg font-extrabold text-red-500">Rs<%= event.price %><span class="text-xs font-normal text-gray-400"> / night</span></span>
                <div class="flex items-center gap-1 bg-yellow-50 px-2 py-1 rounded-full">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-yellow-400">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-gray-700 text-sm font-semibold"><%= event.rating %></span>
                </div>
              </div>

              <div class="flex flex-col gap-2">
    <% if(isLoggedIn) { %>
  <form action="/booked" method="POST">
    <input type="hidden" name="eventId" value="<%= event._id %>">
    <input type="hidden" name="customerId" value="<%= user._id %>">
    <input type ="hidden"name="hostId" value="<%= event.hostId %>">
    <button type="submit" class="w-full bg-green-400 hover:bg-green-500 active:scale-95 text-white font-semibold py-2 px-4 rounded-xl transition-all duration-200">
      Book Now
    </button>
  </form>
<% } %>
                <a href="/events/<%= event._id %>"
                  class="w-full bg-blue-400 hover:bg-blue-500 active:scale-95 text-white font-semibold py-2 px-4 rounded-xl transition-all duration-200 text-center block">
                  View Details
                </a>
                <%- include('../partials/favourite', {event: event}) %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </main>

    <script>
      function filterEvents() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        document.querySelectorAll('.event-card').forEach(card => {
          const name = card.dataset.name.toLowerCase();
          const location = card.dataset.location.toLowerCase();
          card.style.display = (name.includes(query) || location.includes(query)) ? 'block' : 'none';
        });
      }
    </script>

  </body>
</html>