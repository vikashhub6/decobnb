<%- include('../partials/head') %>
  </head>
  <body class="bg-gradient-to-br from-gray-100 to-gray-200 min-h-screen">
      <%- include('../partials/nav') %>
      <main class="container mx-auto max-w-6xl mt-10 px-4 pb-10">

          <!-- 3D Card Wrapper -->
          <div class="bg-white rounded-3xl shadow-2xl overflow-hidden transform hover:scale-[1.01] transition-all duration-500"
               style="box-shadow: 0 20px 60px rgba(0,0,0,0.2), 0 6px 20px rgba(0,0,0,0.15);">

              <!-- Header -->
              <div class="bg-gradient-to-r from-red-500 to-pink-500 py-6 px-8 text-center"
                   style="box-shadow: 0 4px 15px rgba(239,68,68,0.4);">
                  <h2 class="text-4xl font-extrabold text-white tracking-wide drop-shadow-lg">
                      🏠 <%= event.houseName %>
                  </h2>
                  <p class="text-red-100 mt-1 text-sm tracking-widest uppercase">Event Details</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-0">

                  <!-- Image Side -->
                  <div class="relative overflow-hidden group"
                       style="box-shadow: inset -10px 0 30px rgba(0,0,0,0.1);">
                      <img src="<%= event.photo %>" alt="<%= event.name %>"
                           class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 min-h-96">
                      <!-- Overlay -->
                      <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  </div>

                  <!-- Details Side -->
                  <div class="p-8 space-y-5 bg-white"
                       style="box-shadow: inset 5px 0 15px rgba(0,0,0,0.05);">

                      <!-- Description -->
                      <div class="bg-gray-50 rounded-2xl p-4 transform hover:-translate-y-1 transition-all duration-300"
                           style="box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
                          <h3 class="text-lg font-bold text-red-500 mb-1 flex items-center gap-2">
                              📝 Description
                          </h3>
                          <p class="text-gray-600 text-sm leading-relaxed"><%= event.description %></p>
                      </div>

                      <!-- Location -->
                      <div class="bg-gray-50 rounded-2xl p-4 transform hover:-translate-y-1 transition-all duration-300"
                           style="box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
                          <h3 class="text-lg font-bold text-red-500 mb-1 flex items-center gap-2">
                              📍 Location
                          </h3>
                          <p class="text-gray-600 text-sm"><%= event.location %></p>
                      </div>

                      <!-- Price -->
                      <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl p-4 transform hover:-translate-y-1 transition-all duration-300"
                           style="box-shadow: 0 4px 15px rgba(16,185,129,0.15);">
                          <h3 class="text-lg font-bold text-green-600 mb-1 flex items-center gap-2">
                              💰 Price
                          </h3>
                          <p class="text-green-600 text-2xl font-extrabold">Rs <%= event.price %> <span class="text-sm font-normal text-gray-400">/ night</span></p>
                      </div>

                      <!-- Rating -->
                      <div class="bg-gradient-to-r from-yellow-50 to-orange-50 rounded-2xl p-4 transform hover:-translate-y-1 transition-all duration-300"
                           style="box-shadow: 0 4px 15px rgba(234,179,8,0.15);">
                          <h3 class="text-lg font-bold text-yellow-600 mb-1 flex items-center gap-2">
                              ⭐ Rating
                          </h3>
                          <div class="flex items-center gap-2">
                              <span class="text-yellow-400 text-2xl">★★★★★</span>
                              <span class="text-lg font-bold text-gray-700"><%= event.rating %> / 5</span>
                          </div>
                      </div>

<div>
                      <!-- Call Button -->
<a href="tel:<%= event.hostId.mobileNumber %>"
   class="flex items-center justify-center gap-2 bg-blue-500 hover:bg-blue-600 text-white py-2 px-4 rounded-xl font-medium transition duration-300"
   style="box-shadow: 0 4px 10px rgba(59,130,246,0.4);">
    📞 Call Now
</a>

<!-- WhatsApp Button -->
<a href="https://wa.me/91<%= event.hostId.mobileNumber %>?text=Hi! I'm interested in <%= event.EventName %> listed on decobnb. Can we discuss the price?"
   target="_blank"
   class="flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white py-2 px-4 rounded-xl font-medium transition duration-300"
   style="box-shadow: 0 4px 10px rgba(34,197,94,0.4);">
    💬 Chat on WhatsApp
</a>
</div>
                      <!-- Favourite -->
                      <div class="mt-2 transform hover:-translate-y-1 transition-all duration-300">
                          <%- include('../partials/favourite') %>
                      </div>

                  </div>
              </div>
          </div>
      </main>
  </body>
</html>